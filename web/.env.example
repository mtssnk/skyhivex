# Full URL including protocol — in production: https://your-web-domain.up.railway.app (or custom domain)
# Used for canonical URLs and JSON-LD. Without this, Railway's internal address (localhost:8080) leaks into the <head>.
PUBLIC_SITE_URL=http://localhost:4321

# Full URL including protocol — in production: https://your-cms-domain.up.railway.app
CMS_URL=http://localhost:3000

RESEND_API_KEY=
CONTACT_EMAIL=
# e.g. "Snook Studio <hello@snookstudio.co.uk>" — requires a verified domain in Resend. Omit to use onboarding@resend.dev (dev only).
RESEND_FROM=

# Shared with cms/.env — generate with: node -e "console.log(crypto.randomUUID())"
PREVIEW_SECRET=
# Generate in Payload admin: Users → open your user record → enable API Key → copy the value
PAYLOAD_API_KEY=

# Google Tag Manager container ID (e.g. GTM-XXXXXXX) — omit to disable GTM
PUBLIC_GTM_ID=

# Cloudflare Web Analytics beacon token — omit to disable
PUBLIC_CF_BEACON_TOKEN=
