---
import type { MediaTextBlock } from '@/lib/payload'
import MediaItem from '@/components/MediaItem.astro'
import { lexicalToHtml } from '@/lib/lexical'
import clsx from 'clsx'
import ArrowDownRight from '@/assets/icons/arrowDownRight.astro'
import { blockPaddingClass, injectSpans } from '@/lib/blocks'
import Button from '@/components/Button.astro'

const {
  mediaType,
  image,
  video,
  heading,
  headingTag,
  body,
  linkLabel,
  linkType,
  linkUrl,
  linkPage,
  mediaPosition,
  variant,
  aspectRatio,
  anchorId,
  paddingWhere,
  paddingSize,
} = Astro.props as MediaTextBlock
const HeadingTag = (headingTag ?? 'h2') as 'h1' | 'h2' | 'h3' | 'h4'
const html = body ? lexicalToHtml(body) : ''
const linkHref = linkLabel
  ? linkType === 'internal'
    ? `/${linkPage?.slug ?? ''}`
    : (linkUrl ?? '#')
  : null
const isMediaLeft = mediaPosition === 'left'
const paddingClass = blockPaddingClass(paddingWhere, paddingSize)
---

<section id={anchorId ?? undefined} class="section-mediatext bg-ash overflow-x-clip">
  {
    variant === 'contained' ? (
      <div class={clsx('container grid grid-cols-12', paddingClass)}>
        <div
          class={clsx(
            'flex items-center',
            isMediaLeft ? '' : 'lg:col-start-7 md:order-2',
            'col-span-12 md:col-span-6',
          )}
        >
          {mediaType === 'image' && image && (
            <MediaItem
              media={image}
              aspectRatio={aspectRatio ?? 'auto'}
              class="w-full h-auto block"
            />
          )}
          {mediaType === 'video' && video && (
            <MediaItem
              media={video}
              muted={true}
              autoplay={true}
              aspectRatio={aspectRatio ?? 'auto'}
              class="w-full h-auto block"
            />
          )}
        </div>
        <div
          class={clsx(
            'col-span-12 md:col-span-6 flex flex-col justify-center',
            isMediaLeft ? 'lg:col-start-7' : 'lg:col-start-1',
          )}
        >
          <div class="mx-auto max-w-[450px] space-y-2xs">
            {heading && (
              <HeadingTag
                class="text-extended-xl text-white font-light!"
                set:html={injectSpans(heading)}
              />
            )}

            <div class="wysiwyg text-body-xs text-mist" set:html={html} />

            {linkHref && (
              <Button href={linkHref} size="lg" style="text" colour="green">
                {linkLabel}
                <ArrowDownRight />
              </Button>
            )}
          </div>
        </div>
      </div>
    ) : (
      <div class="container grid grid-cols-12">
        <div
          class={clsx(
            'col-span-12 lg:col-span-5 flex flex-col justify-center pb-md pt-4xs lg:py-lg',
          )}
        >
          <div class={clsx('max-w-[450px] space-y-2xs lg:mx-auto')}>
            {heading && (
              <HeadingTag
                class="text-extended-xl text-white font-light!"
                set:html={injectSpans(heading)}
              />
            )}
            <div class="wysiwyg max-w-[420px] text-body-xs text-mist" set:html={html} />
            {linkHref && (
              <Button href={linkHref} size="lg" style="text" colour="green">
                {linkLabel}
                <ArrowDownRight />
              </Button>
            )}
          </div>
        </div>
        <figure
          class={clsx(
            'col-span-12 lg:col-span-7 relative min-h-[60vw] lg:min-h-0 order-first lg:order-0',
            isMediaLeft ? 'lg:col-start-1 lg:row-start-1' : 'lg:col-start-6',
          )}
        >
          <div class={isMediaLeft ? 'media-bleed-left' : 'media-bleed-right'}>
            {mediaType === 'image' && image && (
              <MediaItem media={image} class="w-full h-full object-cover" />
            )}
            {mediaType === 'video' && video && (
              <MediaItem
                media={video}
                muted={true}
                autoplay={true}
                class="w-full h-full object-cover"
              />
            )}
          </div>
        </figure>
      </div>
    )
  }
</section>
