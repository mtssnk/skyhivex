---
import type { FeatureListBlock } from '@/lib/payload'
import HeadingUnderline from '@/components/HeadingUnderline.astro'
import Button from '@/components/Button.astro'
import ArrowUpRight from '@/assets/icons/arrowUpRight.astro'
import Plus from '@/assets/icons/plus.astro'
import clsx from 'clsx'

const { heading, headingTag, items, linkLabel, linkType, linkUrl, linkPage, anchorId } =
  Astro.props as FeatureListBlock

const HeadingTag = (headingTag ?? 'h2') as 'h1' | 'h2' | 'h3' | 'h4'
const linkHref = linkLabel
  ? linkType === 'internal'
    ? `/${linkPage?.slug ?? ''}`
    : (linkUrl ?? '#')
  : null
---

<section id={anchorId ?? undefined} class="section-featurelist bg-ash">
  <header class="container pt-xs">
    {
      heading && (
        <HeadingUnderline>
          <HeadingTag set:html={heading} />
        </HeadingUnderline>
      )
    }
  </header>
  <div class="pt-xs pb-md bg-plus-congo">
    <div class="container">
      <ul class="flex flex-wrap" role="list">
        {
          items.map((item) => (
            <li class="w-full lg:w-1/3 bg-space p-2xs border-congo border-2 lg:border-r-0 last:border-r-2 border-b-0 last:border-b-2 lg:border-b-2">
              <div class="max-w-[400px] flex flex-col mx-auto gap-3xs">
                {item.icon && (
                  <div class="relative self-start w-32 h-32 shrink-0 border-congo border-2">
                    <div class="absolute inset-0 bg-night flex items-center justify-center">
                      <span
                        set:html={item.icon.code}
                        class="w-full h-full [&_svg]:w-full [&_svg]:h-full"
                      />
                    </div>
                    <Plus class="absolute -top-[9px] -left-[9px] text-gravel corner-plus [&_path]:stroke-2" />
                    <Plus class="absolute -top-[9px] -right-[9px] text-gravel corner-plus [&_path]:stroke-2" />
                    <Plus class="absolute -bottom-[9px] -left-[9px] text-gravel corner-plus [&_path]:stroke-2" />
                    <Plus class="absolute -bottom-[9px] -right-[9px] text-gravel corner-plus [&_path]:stroke-2" />
                  </div>
                )}
                <div class="space-y-5xs">
                  <h3 class="text-extended-2xs text-smoke">{item.heading}</h3>
                  {item.body && <p class="text-body-3xs text-mist">{item.body}</p>}
                </div>
              </div>
            </li>
          ))
        }
      </ul>
      {
        linkHref && (
          <div class="w-full flex justify-center pt-xs">
            <Button href={linkHref} size="lg" style="solid" colour="green">
              {linkLabel}
              <ArrowUpRight />
            </Button>
          </div>
        )
      }
    </div>
  </div>
</section>
