---
import type { ProjectListBlock } from '@/lib/payload'
import Button from '@/components/Button.astro'
import HeadingUnderline from '@/components/HeadingUnderline.astro'
import CardProject from '@/components/CardProject.astro'
import { getProjects } from '@/lib/payload'
import type { Project } from '@/lib/payload'

const {
  heading,
  projects,
  selectionMode,
  filterClientType,
  filterRegion,
  filterState,
  filterCity,
  count,
  viewAllLabel,
  anchorId,
} = Astro.props as ProjectListBlock

let resolvedProjects: Project[] = projects ?? []

if (selectionMode !== 'manual') {
  const all = await getProjects()
  let filtered = all

  if (selectionMode === 'filtered') {
    if (filterCity) {
      filtered = filtered.filter((p) => p.city?.id === filterCity.id)
    } else if (filterState) {
      filtered = filtered.filter((p) => p.state?.id === filterState.id)
    } else if (filterRegion) {
      filtered = filtered.filter((p) => p.region?.id === filterRegion.id)
    }
    if (filterClientType) {
      filtered = filtered.filter((p) => p.clientType?.id === filterClientType.id)
    }
  }

  resolvedProjects = count ? filtered.slice(0, count) : filtered
}
---

<section id={anchorId ?? undefined} class="section-projectlist">
  <div class="container pt-xs">
    {
      heading && (
        <header>
          <HeadingUnderline>{heading}</HeadingUnderline>
        </header>
      )
    }
  </div>
  <div class="pt-xs pb-md bg-hexagon-obsidian">
    <ul class="container space-y-xs" role="list">
      {
        resolvedProjects.map((project, i) => (
          <li class="w-full">
            <CardProject
              href={`/projects/${project.slug}`}
              media={project.listingMedia ?? project.listingImage}
              label={project.projectName ?? project.heading}
              category={project.clientType?.name}
              sizes="(max-width: 768px) 100vw, 33vw"
              isEven={i % 2 !== 0}
              number={i + 1}
            />
          </li>
        ))
      }
    </ul>
    {
      viewAllLabel ? (
        <div class="w-full flex justify-center pt-xs">
          <Button href="/projects" style="solid" size="lg" colour="green">
            {viewAllLabel}
          </Button>
        </div>
      ) : null
    }
  </div>
</section>
