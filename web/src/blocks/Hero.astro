---
import type { HeroBlock } from '@/lib/payload'
import MediaItem from '@/components/MediaItem.astro'
import Button from '@/components/Button.astro'
import HexShader from '@/components/HexShader.astro'

interface Props extends Omit<HeroBlock, 'blockType'> {}

const {
  heading,
  subtitle,
  intro,
  backgroundMedia,
  backgroundImage,
  backgroundVideo,
  overlayAlpha,
  buttons,
  anchorId,
} = Astro.props

const bgMedia =
  backgroundMedia === 'image'
    ? backgroundImage
    : backgroundMedia === 'video'
      ? backgroundVideo
      : null
---

<header
  id={anchorId ?? undefined}
  class="section-hero relative min-h-[80vh] flex items-center bg-night text-white overflow-hidden"
>
  {
    bgMedia ? (
      <>
        <div class="absolute inset-0" aria-hidden="true">
          <MediaItem media={bgMedia} sizes="100vw" muted class="w-full h-full object-cover" />
        </div>
        <div
          class="absolute inset-0 bg-black"
          style={`opacity: ${overlayAlpha ?? 0.3}`}
          aria-hidden="true"
        />
      </>
    ) : backgroundMedia === 'shader' ? (
      <HexShader />
    ) : null
  }
  <div class="container relative py-md">
    {heading && <h1 class="text-wide-xl text-ash whitespace-pre-line max-w-[10em]">{heading}</h1>}
    {subtitle && <p class="text-body-md text-ash mt-4">{subtitle}</p>}
    {intro && <div class="text-body-md text-ash text-balance mt-10 max-w-[28em]">{intro}</div>}
    {
      buttons && buttons.length > 0 && (
        <div class="flex flex-wrap gap-y-4 gap-x-8 items-center mt-sm">
          {buttons.map((btn) => {
            if (btn.type === 'video') {
              return (
                <Button
                  colour={btn.colour}
                  style={btn.variant}
                  data-video-url={btn.videoFile?.url ?? ''}
                >
                  {btn.label}
                </Button>
              )
            }
            const href = btn.type === 'anchor' ? `#${btn.anchorTarget ?? ''}` : (btn.linkUrl ?? '#')
            return (
              <Button href={href} colour={btn.colour} style={btn.variant}>
                {btn.label}
              </Button>
            )
          })}
        </div>
      )
    }
  </div>
</header>
