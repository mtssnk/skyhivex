---
import type { CTABlock } from '@/lib/payload'
import MediaItem from '@/components/MediaItem.astro'
import Button from '@/components/Button.astro'
import ArrowDownRight from '@/assets/icons/arrowDownRight.astro'
import Play from '@/assets/icons/play.astro'
import HexShader from '@/components/HexShader.astro'
import { resolveButtonHref } from '@/lib/blocks'

interface Props extends Omit<CTABlock, 'blockType'> {}

const {
  headingPart1,
  headingPart2,
  intro,
  body,
  backgroundMedia,
  backgroundImage,
  backgroundVideo,
  overlayAlpha,
  buttons,
  anchorId,
} = Astro.props

const bgMedia =
  backgroundMedia === 'image'
    ? backgroundImage
    : backgroundMedia === 'video'
      ? backgroundVideo
      : null
---

<div
  id={anchorId ?? undefined}
  class="section-hero relative min-h-[80vh] flex items-center bg-night text-white overflow-hidden"
>
  {
    bgMedia ? (
      <>
        <div class="absolute inset-0" aria-hidden="true">
          <MediaItem media={bgMedia} sizes="100vw" muted class="w-full h-full object-cover" />
        </div>
        <div
          class="absolute inset-0 bg-black"
          style={`opacity: ${overlayAlpha ?? 0.4}`}
          aria-hidden="true"
        />
      </>
    ) : backgroundMedia === 'shader' ? (
      <HexShader />
    ) : null
  }

  <div class="container relative py-sm flex flex-col items-center text-center gap-5xs">
    {
      backgroundMedia === 'shader' && (
        <div
          class="absolute inset-0 z-0 pointer-events-none"
          style="background: radial-gradient(ellipse at center, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0) 70%)"
          aria-hidden="true"
        />
      )
    }
    <div class="relative z-10 space-y-2xs">
      <div class="space-y-5xs">
        {
          headingPart1 || headingPart2 ? (
            <h1 class="text-white space-y-5xs">
              {headingPart1 && (
                <span class="text-extended-xl uppercase w-full inline-flex justify-center max-w-[28em] text-balance">
                  {headingPart1}
                </span>
              )}
              {headingPart2 && (
                <p class="text-serif-5xl w-full inline-flex justify-center">{headingPart2}</p>
              )}
            </h1>
          ) : null
        }
        {intro && <p class="text-extended-md mx-auto max-w-[24em]">{intro}</p>}
        {body && <p class="text-body-sm mx-auto max-w-[36em] text-balance">{body}</p>}
      </div>
      {
        buttons && buttons.length > 0 && (
          <div class="flex flex-wrap gap-y-4 gap-3xs items-center justify-center">
            {buttons.map((btn) => {
              if (btn.type === 'video') {
                return (
                  <Button
                    colour={btn.colour}
                    style={btn.variant}
                    size="lg"
                    data-video-url={btn.videoFile?.url ?? ''}
                  >
                    {btn.label}
                    <Play />
                  </Button>
                )
              }
              const href =
                btn.type === 'anchor' ? `#${btn.anchorTarget ?? ''}` : resolveButtonHref(btn.linkUrl)
              return (
                <Button href={href} colour={btn.colour} style={btn.variant} size="lg">
                  {btn.label}
                  {btn.type === 'anchor' && <ArrowDownRight />}
                </Button>
              )
            })}
          </div>
        )
      }
    </div>
  </div>
</div>
