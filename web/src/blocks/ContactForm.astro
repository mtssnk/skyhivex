---
import clsx from 'clsx'
import type { ContactFormBlock } from '@/lib/payload'
import { blockPaddingClass } from '@/lib/blocks'
import { lexicalToHtml } from '@/lib/lexical'
import ContactForm from '@/components/ContactForm.astro'

const { heading, body, anchorId, paddingWhere, paddingSize } = Astro.props as ContactFormBlock
const paddingClass = blockPaddingClass(paddingWhere, paddingSize)
const bodyHtml = body ? lexicalToHtml(body) : null
---

<section id={anchorId ?? undefined} class={clsx('section-contactform', paddingClass)}>
  <div class="container max-w-[640px]!">
    <div class="space-y-3xs">
      <h2 class="text-serif-2xl text-white">{heading}</h2>
      {bodyHtml && <div class="wysiwyg text-body-xs text-mist" set:html={bodyHtml} />}
    </div>
    <div class="mt-3xs">
      <ContactForm />
    </div>
  </div>
</section>
