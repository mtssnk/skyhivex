---
import type { LinkedContentBlock } from '@/lib/payload'
import HeadingUnderLine from '@/components/HeadingUnderline.astro'
import Button from '@/components/Button.astro'
import { clsx } from 'clsx'
import { blockPaddingClass } from '@/lib/blocks'
import { lexicalToHtml } from '@/lib/lexical'
import ArrowUpRight from '@/assets/icons/arrowUpRight.astro'
const { navigation, body, anchorId, paddingWhere, paddingSize } = Astro.props as LinkedContentBlock
const paddingClass = blockPaddingClass(paddingWhere, paddingSize)
const bodyHtml = body ? lexicalToHtml(body) : null
const currentPath = Astro.url.pathname
---

<section id={anchorId ?? undefined} class="section-linkedcontent">
  <div class={clsx('container', paddingClass)}>
    <div class="grid grid-cols-12 lg:gap-xs">
      <div class="col-span-12 md:col-span-5 lg:col-span-4">
        {
          navigation?.links && navigation.links.length > 0 && (
            <nav aria-label={navigation.name}>
              {navigation?.name && <HeadingUnderLine>{navigation.name}</HeadingUnderLine>}
              <ul class="flex flex-col gap-4xs pt-3xs" role="list">
                {navigation.links.map((link) => {
                  const href = link.page?.slug
                    ? link.page.slug === 'home'
                      ? '/'
                      : `/${link.page.slug}`
                    : (link.url ?? '#')
                  const isActive = currentPath === href
                  return (
                    <li>
                      <Button
                        href={href}
                        style="text"
                        size="lg"
                        colour={isActive ? 'green' : 'white'}
                      >
                        {link.label}
                        <ArrowUpRight />
                      </Button>
                    </li>
                  )
                })}
              </ul>
            </nav>
          )
        }
      </div>
      <div class="col-span-12 md:col-span-7 lg:col-span-8">
        {bodyHtml && <div class="wysiwyg max-w-[640px] text-body-xs" set:html={bodyHtml} />}
      </div>
    </div>
  </div>
</section>
