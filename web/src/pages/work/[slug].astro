---
import Layout from '@/layouts/Layout.astro'
import BlockRenderer from '@/blocks/BlockRenderer.astro'
import { getProjects, getProjectBySlug } from '@/lib/payload'
import Hero from '@/blocks/Hero.astro'

export async function getStaticPaths() {
  const projects = await getProjects()
  return projects.map((p) => ({ params: { slug: p.slug } }))
}

const { slug } = Astro.params
const project = await getProjectBySlug(slug!)
if (!project) return new Response(null, { status: 404 })

const metaDescription = project.metaDescription ?? project.heading
const ogImage = project.ogImage?.url ?? project.heroMedia?.image?.url ?? project.listingMedia?.url
const isDark = project.isDark ?? true

const heroMediaType = project.heroMedia?.type ?? (project.listingMedia ? 'image' : undefined)
const heroBackgroundImage = project.heroMedia?.image ?? project.listingMedia ?? undefined
const heroBackgroundVideo = project.heroMedia?.video ?? undefined

const jsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: project.projectName ?? project.heading,
  description: metaDescription,
  url: Astro.url.href,
  creator: { '@type': 'Organization', name: 'Snook Studio', url: Astro.url.origin },
}
if (ogImage) jsonLd.image = ogImage

const heroButtons: NonNullable<Parameters<typeof Hero>[0]['buttons']> = [
  { label: 'Find out more', type: 'anchor', anchorTarget: 'work-content', variant: 'solid', colour: 'white' },
  ...(project.url
    ? [{ label: 'View project', type: 'link' as const, linkUrl: project.url, variant: 'outline' as const, colour: 'white' as const }]
    : []),
]
---

<Layout
  title={project.projectName ?? project.heading}
  description={metaDescription}
  isDark={isDark}
  {ogImage}
  {jsonLd}
>
  <Hero
    headingPart1={project.heading}
    backgroundMedia={heroMediaType}
    backgroundImage={heroBackgroundImage}
    backgroundVideo={heroBackgroundVideo}
    buttons={heroButtons}
  />

  <div id="work-content"></div>
  <BlockRenderer blocks={project.blocks} />
</Layout>
