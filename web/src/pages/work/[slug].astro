---
import Layout from '@/layouts/Layout.astro'
import BlockRenderer from '@/blocks/BlockRenderer.astro'
import { getProjects, getProjectBySlug } from '@/lib/payload'
import Hero from '@/blocks/Hero.astro'

export async function getStaticPaths() {
  const projects = await getProjects()
  return projects.map((p) => ({ params: { slug: p.slug } }))
}

const { slug } = Astro.params
const work = await getProjectBySlug(slug!)
if (!work) return new Response(null, { status: 404 })

const heroMedia = work.heroMedia ?? work.listingMedia
const metaDescription = work.metaDescription ?? `${work.client} — ${work.title}`
const ogImage = work.ogImage?.url ?? heroMedia?.url ?? undefined
const isDark = work.isDark ?? true
const services = work.services?.map((s) => s.service).join(', ')
const prefix = services ? `${work.client} — ${services}` : work.client

const jsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: work.projectName,
  description: metaDescription,
  url: Astro.url.href,
  creator: { '@type': 'Organization', name: 'Snook Studio', url: Astro.url.origin },
}
if (ogImage) jsonLd.image = ogImage

const heroButtons = [
  { label: 'Find out more', type: 'scroll' as const, anchorId: 'work-content' },
  ...(work.url
    ? [{ label: 'View project', type: 'page' as const, url: work.url, target: '_blank' as const }]
    : []),
]
---

<Layout
  title={`${work.client} — ${work.title}`}
  description={metaDescription}
  isDark={isDark}
  {ogImage}
  {jsonLd}
>
  <Hero heading={work.title} {prefix} backgroundMedia={heroMedia} buttons={heroButtons} />

  <div id="work-content"></div>
  <BlockRenderer blocks={work.body} />
</Layout>
