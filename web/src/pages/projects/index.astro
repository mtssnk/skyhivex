---
import Layout from '@/layouts/Layout.astro'
import CardLink from '@/components/CardLink.astro'
import BlockRenderer from '@/blocks/BlockRenderer.astro'
import { getProjects, getProjectsPage } from '@/lib/payload'

const [projects, projectsPage] = await Promise.all([getProjects(), getProjectsPage()])
---

<Layout
  title="Projects"
  description={projectsPage?.metaDescription ?? undefined}
  ogImage={projectsPage?.ogImage?.url ?? undefined}
>
  <section class="bg-terracotta relative">
    <div class="flex flex-col gap-sm py-lg relative z-10">
      {
        (projectsPage?.heading || projectsPage?.intro) && (
          <div class="container grid">
            <div class="col-span-12 space-y-6 md:space-y-10 max-w-[36em] ">
              {projectsPage.heading && (
                <h1 class="text-wide-lg whitespace-pre-line">{projectsPage.heading}</h1>
              )}
              {projectsPage.intro && <p class="text-body-md text-balance">{projectsPage.intro}</p>}
            </div>
          </div>
        )
      }
      <div class="container grid">
        {
          projects.map((project) => (
            <div class="col-span-12 md:col-span-4">
              <CardLink
                href={`/projects/${project.slug}`}
                media={project.listingMedia ?? project.listingImage}
                label={project.projectName ?? project.heading}
                sizes="(max-width: 768px) 100vw, 33vw"
              />
            </div>
          ))
        }
      </div>
    </div>
  </section>
  <BlockRenderer blocks={projectsPage?.blocks} />
</Layout>
