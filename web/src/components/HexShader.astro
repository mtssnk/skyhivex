<canvas class="w-full h-full z-0 absolute inset-0" id="canvas"></canvas>

<script>
  import { createRenderer } from '../lib/shader-renderer.js'
  import fragSrc from '../lib/hex-shader.frag?raw'

  const MAX_PIXEL_RATIO = 1.5

  async function main() {
    const canvas = document.getElementById('canvas') as HTMLCanvasElement

    let renderer
    try {
      renderer = createRenderer(canvas, fragSrc, {
        maxPixelRatio: MAX_PIXEL_RATIO,
      })
    } catch (err) {
      showError(`WebGL / shader error:\n${(err as Error).message}`)
      return
    }

    renderer.start()

    document.addEventListener('visibilitychange', () => {
      document.hidden ? renderer.stop() : renderer.start()
    })
  }

  function showError(msg: string) {
    const el = document.createElement('pre')
    Object.assign(el.style, {
      position: 'fixed',
      inset: '2rem',
      background: 'rgba(0,0,0,.85)',
      color: '#f66',
      padding: '1.5rem',
      borderRadius: '6px',
      whiteSpace: 'pre-wrap',
      font: '13px/1.5 monospace',
    })
    el.textContent = msg
    document.body.appendChild(el)
    console.error(msg)
  }

  main()
</script>
