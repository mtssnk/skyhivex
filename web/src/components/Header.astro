---
import Button from '@/components/Button.astro'
import { getNavigation } from '@/lib/payload'

interface Props {
  isDark?: boolean
}
const { isDark } = Astro.props

const nav = await getNavigation()
const links = nav?.links ?? []
const btn = nav?.button?.enabled ? nav.button : null

function linkHref(item: {
  type?: string | null
  page?: { slug: string } | null
  url?: string | null
}): string {
  if (item.type === 'work') return '/work'
  if (item.type === 'page' && item.page?.slug) {
    return item.page.slug === 'home' ? '/' : `/${item.page.slug}`
  }
  if (item.type === 'url' && item.url) return item.url
  return '#'
}
---

<header
  class={`snk-header flex items-center fixed w-full z-50 top-0 left-0 ${isDark ? 'text-white' : 'text-night'}`}
>
  <div class="container flex items-center justify-between">
    <a href="/" class="relative z-10" aria-label="Snook Studio">
      <svg
        width="168"
        height="29"
        xmlns="http://www.w3.org/2000/svg"
        xml:space="preserve"
        viewBox="0 0 168 29"
        ><path
          d="M12 3.6 0 12.7l4.3 3.2c-.6 1.2-.9 2.6-.9 4 0 5 3.9 9.1 8.6 9.1v-3.6l12-9.1-4.3-3.2c.6-1.2.9-2.5.9-4 0-5-3.9-9.1-8.6-9.1zM6.8 19.9c0-.7.1-1.3.3-1.9l4.9 3.7v3.6c-2.8.1-5.2-2.4-5.2-5.4m12.4-3.6-4.8 3.6-9.6-7.3L9.6 9zm-2-7.2q0 .9-.3 1.8L12 7.2V3.6c2.9 0 5.2 2.5 5.2 5.5m20.2 9.1h2.4c.1 1.1.6 2.1 1.8 2.1s1.6-.7 1.6-1.8-.5-1.8-2.2-2.6c-2.3-1.1-3.2-2.1-3.2-4.1 0-2.2 1.4-3.6 3.8-3.6 3.1 0 3.8 2.1 3.8 3.8H43c-.1-.8-.3-1.9-1.5-1.9-1 0-1.4.6-1.4 1.5 0 1 .4 1.4 2 2.2 2.4 1.1 3.5 2.2 3.5 4.5 0 2.1-1.3 3.9-4.2 3.9s-3.9-2-4-4M52.2 22H50V8.5h2.7c2.8 7.5 3.3 8.9 3.5 9.6-.1-1.6-.1-3.6-.1-5.8V8.5h2.2V22h-2.6c-2.9-8-3.4-9.4-3.6-10 .1 1.7.1 3.7.1 6.1zM67.3 8.3c3 0 4.4 2.2 4.4 6.9 0 4.9-1.3 7.1-4.5 7.1-2.9 0-4.3-2.1-4.3-7.1s1.6-6.9 4.4-6.9m0 2c-1.5 0-1.9 1.8-1.9 4.8 0 3.2.5 5.1 1.9 5.1 1.5 0 1.9-1.8 1.9-5.1 0-3.2-.5-4.8-1.9-4.8m12.9-2c3 0 4.4 2.2 4.4 6.9 0 4.9-1.3 7.1-4.5 7.1-2.9 0-4.3-2.1-4.3-7.1s1.7-6.9 4.4-6.9m0 2c-1.5 0-1.9 1.8-1.9 4.8 0 3.2.5 5.1 1.9 5.1 1.5 0 1.9-1.8 1.9-5.1 0-3.2-.4-4.8-1.9-4.8M89.1 22V8.5h2.4v6.1c.8-1.2 2.5-4.3 3.6-6.1h2.8l-3.5 5.3L98 22h-2.7l-2.5-6.2-1.2 1.7V22zm18-3.5h1.2c.1 1.5.9 2.7 2.4 2.7s2.3-.8 2.3-2.6c0-1.6-.6-2.4-2.5-3.3-2.1-1-3-1.9-3-3.9 0-1.8 1.1-3.3 3.3-3.3 2.5 0 3.2 1.8 3.2 3.4h-1.1c-.1-.6-.3-2.4-2.1-2.4-1.4 0-2 1-2 2.2 0 1.4.6 2.1 2.4 2.9 2.4 1.1 3.1 2.3 3.1 4.2 0 2.2-1.2 3.7-3.5 3.7-2.8.1-3.6-1.6-3.7-3.6m13.5 3.5V9.4h-3.1v-1h7.3v1h-3.1V22zm8.2-13.6h1.2V18c0 1.7.5 3.2 2.4 3.2s2.4-1.3 2.4-3.2V8.4h1.1V18c0 2.5-.9 4.2-3.6 4.2-2.6 0-3.5-1.6-3.5-4.1zM141.3 22V8.4h2.8c3 0 4.4 2.2 4.4 6.4 0 4.6-1.3 7.2-4.7 7.2zm1.1-12.6V21h1.4c2.7 0 3.5-2.2 3.5-6.1 0-3.8-1.1-5.5-3.5-5.5zm11-1h1.2V22h-1.2zm9.9-.2c2.8 0 3.8 2.3 3.8 6.9 0 4.5-1 7.1-3.9 7.1-2.8 0-3.8-2.5-3.8-7.1 0-4.5 1.3-6.9 3.9-6.9m-.1 1c-1.7 0-2.6 1.9-2.6 5.8 0 4.1.9 6.1 2.7 6.1s2.7-1.9 2.7-6c-.1-4.2-1-5.9-2.8-5.9"
          fill="currentColor"></path></svg
      >
    </a>

    <div class="flex items-center gap-4">
      <nav
        id="main-nav"
        class="fixed inset-0 z-0 flex flex-col items-center justify-center gap-8 bg-night text-ash -translate-x-full transition-transform duration-300 data-[open]:translate-x-0 md:static md:inset-auto md:z-auto md:flex-row md:items-center md:gap-6 md:bg-transparent md:text-inherit md:translate-x-0 md:transition-none"
        aria-label="Main navigation"
      >
        {
          links.map((link) => (
            <a href={linkHref(link)} class="text-condensed-md">
              {link.label}
            </a>
          ))
        }
        {
          btn?.label && (
            <Button href={linkHref(btn)} size="md" colour={isDark ? 'white' : 'primary'}>
              {btn.label}
            </Button>
          )
        }
      </nav>

      <button
        id="nav-toggle"
        class="relative z-10 md:hidden flex flex-col items-center justify-center gap-1.5 size-8 cursor-pointer"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="main-nav"
      >
        <span class="block w-6 h-0.5 bg-current transition-all duration-200 origin-center"></span>
        <span class="block w-6 h-0.5 bg-current transition-all duration-200 origin-center"></span>
        <span class="block w-6 h-0.5 bg-current transition-all duration-200 origin-center"></span>
      </button>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle')!
  const nav = document.getElementById('main-nav')!
  const bars = toggle.querySelectorAll<HTMLElement>('span')

  const openNav = () => {
    nav.setAttribute('data-open', '')
    toggle.setAttribute('aria-expanded', 'true')
    toggle.setAttribute('aria-label', 'Close menu')
    document.body.style.overflow = 'hidden'
    bars[0].style.transform = 'translateY(7px) rotate(45deg)'
    bars[1].style.opacity = '0'
    bars[2].style.transform = 'translateY(-9px) rotate(-45deg)'
    nav.querySelector<HTMLElement>('a')?.focus()
  }

  const closeNav = () => {
    nav.removeAttribute('data-open')
    toggle.setAttribute('aria-expanded', 'false')
    toggle.setAttribute('aria-label', 'Open menu')
    document.body.style.overflow = ''
    bars[0].style.transform = ''
    bars[1].style.opacity = ''
    bars[2].style.transform = ''
  }

  toggle.addEventListener('click', () => {
    nav.hasAttribute('data-open') ? closeNav() : openNav()
  })

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && nav.hasAttribute('data-open')) closeNav()
  })

  nav.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeNav))

  window.matchMedia('(min-width: 768px)').addEventListener('change', ({ matches }) => {
    if (matches) closeNav()
  })
</script>
