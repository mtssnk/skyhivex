---
import Button from '@/components/Button.astro'
import { getNavigation } from '@/lib/payload'

interface Props {
  isDark?: boolean
  companyName?: string
}
const { isDark, companyName } = Astro.props

const nav = await getNavigation()
const links = nav?.links ?? []
const btn = nav?.button?.enabled ? nav.button : null

function linkHref(item: {
  type?: string | null
  page?: { slug: string } | null
  url?: string | null
}): string {
  if (item.type === 'work') return '/work'
  if (item.type === 'page' && item.page?.slug) {
    return item.page.slug === 'home' ? '/' : `/${item.page.slug}`
  }
  if (item.type === 'url' && item.url) return item.url
  return '#'
}
---

<header
  class={`snk-header flex items-center fixed w-full z-50 top-0 left-0 ${isDark ? 'text-white' : 'text-night'}`}
>
  <div class="container flex items-center justify-between">
    <a
      href="/"
      class="inline-block w-30 md:w-36 lg:w-42"
      aria-label={companyName ? `${companyName} Home` : 'Home'}
    >
      <img
        src="/src/assets/img/skyhive-logo-white.png"
        alt={companyName ? `${companyName} logo` : 'Logo'}
        class="w-full h-auto"
      />
    </a>

    <div class="flex items-center gap-4">
      <nav
        id="main-nav"
        class="fixed inset-0 z-0 flex flex-col items-center justify-center gap-8 bg-night text-ash -translate-x-full transition-transform duration-300 data-[open]:translate-x-0 md:static md:inset-auto md:z-auto md:flex-row md:items-center md:gap-6 md:bg-transparent md:text-inherit md:translate-x-0 md:transition-none"
        aria-label="Main navigation"
      >
        {
          links.map((link) => (
            <a href={linkHref(link)} class="text-condensed-md">
              {link.label}
            </a>
          ))
        }
        {
          btn?.label && (
            <Button href={linkHref(btn)} size="md" colour={isDark ? 'white' : 'primary'}>
              {btn.label}
            </Button>
          )
        }
      </nav>

      <button
        id="nav-toggle"
        class="relative z-10 md:hidden flex flex-col items-center justify-center gap-1.5 size-8 cursor-pointer"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="main-nav"
      >
        <span class="block w-6 h-0.5 bg-current transition-all duration-200 origin-center"></span>
        <span class="block w-6 h-0.5 bg-current transition-all duration-200 origin-center"></span>
        <span class="block w-6 h-0.5 bg-current transition-all duration-200 origin-center"></span>
      </button>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle')!
  const nav = document.getElementById('main-nav')!
  const bars = toggle.querySelectorAll<HTMLElement>('span')

  const openNav = () => {
    nav.setAttribute('data-open', '')
    toggle.setAttribute('aria-expanded', 'true')
    toggle.setAttribute('aria-label', 'Close menu')
    document.body.style.overflow = 'hidden'
    bars[0].style.transform = 'translateY(7px) rotate(45deg)'
    bars[1].style.opacity = '0'
    bars[2].style.transform = 'translateY(-9px) rotate(-45deg)'
    nav.querySelector<HTMLElement>('a')?.focus()
  }

  const closeNav = () => {
    nav.removeAttribute('data-open')
    toggle.setAttribute('aria-expanded', 'false')
    toggle.setAttribute('aria-label', 'Open menu')
    document.body.style.overflow = ''
    bars[0].style.transform = ''
    bars[1].style.opacity = ''
    bars[2].style.transform = ''
  }

  toggle.addEventListener('click', () => {
    nav.hasAttribute('data-open') ? closeNav() : openNav()
  })

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && nav.hasAttribute('data-open')) closeNav()
  })

  nav.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeNav))

  window.matchMedia('(min-width: 768px)').addEventListener('change', ({ matches }) => {
    if (matches) closeNav()
  })
</script>
