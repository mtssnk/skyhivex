---
import Button from '@/components/Button.astro'
import { getNavigation } from '@/lib/payload'
import ArrowUpRight from '@/assets/icons/arrowUpRight.astro'
import ChevronDown from '@/assets/icons/chevronDown.astro'

interface Props {
  companyName?: string
}
const { companyName } = Astro.props

const nav = await getNavigation()
const links = nav?.header?.links ?? []
const btn = nav?.header?.button?.enabled ? nav.header!.button : null

function linkHref(item: {
  type?: string | null
  page?: { slug: string } | null
  url?: string | null
}): string {
  if (item.type === 'projects') return '/projects'
  if (item.type === 'news') return '/news'
  if (item.type === 'page' && item.page?.slug) {
    return item.page.slug === 'home' ? '/' : `/${item.page.slug}`
  }
  if (item.type === 'url' && item.url) return item.url
  return '#'
}
---

<header class="snk-header flex items-center fixed w-full z-50 top-0 left-0 text-white">
  <div class="container flex items-center justify-between">
    <a
      href="/"
      class="inline-block w-30 md:w-36 lg:w-42"
      aria-label={companyName ? `${companyName} Home` : 'Home'}
    >
      <img
        src="/src/assets/img/skyhive-logo-white.png"
        alt={companyName ? `${companyName} logo` : 'Logo'}
        class="w-full h-auto"
      />
    </a>

    <nav class="hidden lg:flex items-center gap-6" aria-label="Main navigation">
      {
        links.map((link) =>
          link.type === 'dropdown' ? (
            <div class="relative" data-dropdown>
              <button
                class="text-mono-3xs flex items-center gap-1.5 nav-item"
                aria-haspopup="true"
                aria-expanded="false"
                data-dropdown-trigger
              >
                {link.label}
                <ChevronDown class="dropdown-chevron transition-transform size-3" />
              </button>
              <div class="nav-item-dropdown absolute top-full left-0 bg-gravel" data-dropdown-panel>
                {link?.children?.map((child) => (
                  <a href={linkHref(child)} class="text-mono-3xs block">
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a href={linkHref(link)} class="text-mono-3xs nav-item">
              {link.label}
            </a>
          ),
        )
      }
    </nav>

    <div class="flex items-center gap-4">
      {
        btn?.label && (
          <Button
            href={linkHref(btn)}
            size="sm"
            colour="white"
            style="outline"
            class="hidden xs:inline-flex"
          >
            {btn.label}
            <ArrowUpRight />
          </Button>
        )
      }
      <button
        id="nav-toggle"
        class="lg:hidden flex flex-col items-center justify-center gap-1.5 size-8 cursor-pointer"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <span class="block w-6 h-0.5 bg-current transition-all duration-200 origin-center"></span>
        <span class="block w-6 h-0.5 bg-current transition-all duration-200 origin-center"></span>
        <span class="block w-6 h-0.5 bg-current transition-all duration-200 origin-center"></span>
      </button>
    </div>
  </div>
</header>

<nav
  id="mobile-nav"
  class="fixed inset-0 z-40 flex flex-col items-center justify-center gap-8 bg-night text-white -translate-x-full transition-transform duration-300 data-open:translate-x-0 lg:hidden"
  aria-label="Mobile navigation"
>
  {
    links.map((link) =>
      link.type === 'dropdown' ? (
        <div data-mobile-dropdown>
          <button
            class="text-mono-2xs flex gap-1.5 w-full items-center justify-center"
            aria-expanded="false"
            data-mobile-dropdown-trigger
          >
            {link.label}
            <ChevronDown class="mobile-dropdown-chevron transition-transform size-3" />
          </button>
          <div
            class="grid grid-cols-1 grid-rows-[0fr] transition-[grid-template-rows] duration-300"
            data-mobile-dropdown-panel
          >
            <div class="overflow-hidden min-h-0 flex flex-col justify-center text-center first:mt-2 last:bb-2">
              {link?.children?.map((child) => (
                <a href={linkHref(child)} class="text-mono-3xs py-3">
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        </div>
      ) : (
        <a href={linkHref(link)} class="text-mono-2xs">
          {link.label}
        </a>
      ),
    )
  }
  {
    btn?.label && (
      <Button href={linkHref(btn)} size="md" colour="white" style="solid">
        {btn.label}
        <ArrowUpRight />
      </Button>
    )
  }
</nav>

<script>
  // --- Mobile nav ---
  const toggle = document.getElementById('nav-toggle')!
  const nav = document.getElementById('mobile-nav')!
  const bars = toggle.querySelectorAll<HTMLElement>('span')

  const openNav = () => {
    nav.setAttribute('data-open', '')
    toggle.setAttribute('aria-expanded', 'true')
    toggle.setAttribute('aria-label', 'Close menu')
    document.body.style.overflow = 'hidden'
    bars[0].style.transform = 'translateY(7px) rotate(45deg)'
    bars[1].style.opacity = '0'
    bars[2].style.transform = 'translateY(-9px) rotate(-45deg)'
    nav.querySelector<HTMLElement>('a')?.focus()
  }

  const closeNav = () => {
    nav.removeAttribute('data-open')
    toggle.setAttribute('aria-expanded', 'false')
    toggle.setAttribute('aria-label', 'Open menu')
    document.body.style.overflow = ''
    bars[0].style.transform = ''
    bars[1].style.opacity = ''
    bars[2].style.transform = ''
    // collapse all mobile dropdowns
    nav.querySelectorAll('[data-mobile-dropdown-panel]').forEach((panel) => {
      panel.classList.remove('grid-rows-[1fr]')
      panel.classList.add('grid-rows-[0fr]')
    })
    nav.querySelectorAll('[data-mobile-dropdown-trigger]').forEach((t) => {
      t.setAttribute('aria-expanded', 'false')
      t.querySelector('.mobile-dropdown-chevron')?.classList.remove('rotate-x-180')
    })
  }

  toggle.addEventListener('click', () => {
    nav.hasAttribute('data-open') ? closeNav() : openNav()
  })

  nav.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeNav))

  window.matchMedia('(min-width: 1024px)').addEventListener('change', ({ matches }) => {
    if (matches) closeNav()
  })

  // --- Mobile dropdowns ---
  nav.querySelectorAll<HTMLButtonElement>('[data-mobile-dropdown-trigger]').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const expanded = trigger.getAttribute('aria-expanded') === 'true'
      const panel = trigger.nextElementSibling as HTMLElement | null
      trigger.setAttribute('aria-expanded', String(!expanded))
      panel?.classList.toggle('grid-rows-[1fr]', !expanded)
      panel?.classList.toggle('grid-rows-[0fr]', expanded)
      trigger.querySelector('.mobile-dropdown-chevron')?.classList.toggle('rotate-x-180', !expanded)
    })
  })

  // --- Desktop dropdowns ---
  const HOVER_DELAY = 150

  document.querySelectorAll<HTMLElement>('[data-dropdown]').forEach((dropdown) => {
    const trigger = dropdown.querySelector<HTMLButtonElement>('[data-dropdown-trigger]')!
    const panel = dropdown.querySelector<HTMLElement>('[data-dropdown-panel]')!
    let timer: ReturnType<typeof setTimeout>

    const open = () => {
      clearTimeout(timer)
      trigger.setAttribute('aria-expanded', 'true')
      trigger.querySelector('.dropdown-chevron')?.classList.add('rotate-x-180')
    }

    const close = () => {
      clearTimeout(timer)
      timer = setTimeout(() => {
        trigger.setAttribute('aria-expanded', 'false')
        trigger.querySelector('.dropdown-chevron')?.classList.remove('rotate-x-180')
      }, HOVER_DELAY)
    }

    dropdown.addEventListener('mouseenter', open)
    dropdown.addEventListener('mouseleave', close)
    trigger.addEventListener('click', () => {
      trigger.getAttribute('aria-expanded') === 'true' ? close() : open()
    })
  })

  // Close desktop dropdowns on outside click or Escape
  document.addEventListener('click', (e) => {
    document.querySelectorAll<HTMLElement>('[data-dropdown]').forEach((dropdown) => {
      if (!dropdown.contains(e.target as Node)) {
        const trigger = dropdown.querySelector<HTMLButtonElement>('[data-dropdown-trigger]')!
        trigger.setAttribute('aria-expanded', 'false')
        trigger.querySelector('.dropdown-chevron')?.classList.remove('rotate-x-180')
      }
    })
  })

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      if (nav.hasAttribute('data-open')) {
        closeNav()
      } else {
        document.querySelectorAll<HTMLElement>('[data-dropdown]').forEach((dropdown) => {
          const trigger = dropdown.querySelector<HTMLButtonElement>('[data-dropdown-trigger]')!
          if (trigger.getAttribute('aria-expanded') === 'true') {
            trigger.setAttribute('aria-expanded', 'false')
            trigger.querySelector('.dropdown-chevron')?.classList.remove('rotate-x-180')
            trigger.focus()
          }
        })
      }
    }
  })
</script>
