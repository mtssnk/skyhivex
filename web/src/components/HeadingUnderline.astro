---
import clsx from 'clsx'
interface Props {
  class?: string
}

const { class: className } = Astro.props
---

<div class={clsx('border-b-2 border-congo text-gravel', className)}>
  <div class="inline-flex border-b-6 border-congo text-mono-3xs pb-3xs -mb-0.5 items-center gap-8">
    <slot />
  </div>
</div>
