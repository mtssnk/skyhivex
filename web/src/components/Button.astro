---
import clsx from 'clsx'
interface Props {
  colour?: 'green' | 'white'
  size?: 'lg' | 'md' | 'sm'
  style?: 'solid' | 'outline' | 'text' | 'icon'
  as?: 'span'
  href?: string
  target?: string
  rel?: string
  type?: 'button' | 'submit' | 'reset'
  class?: string
}

const {
  colour = 'green',
  size = 'md',
  style = 'solid',
  as: tag,
  href,
  target,
  rel,
  type = 'button',
  class: className,
  ...rest
} = Astro.props

const sizeClasses: Record<string, string> = {
  lg: 'btn-lg',
  md: 'btn-md',
  sm: 'btn-sm',
}

const solidClasses: Record<string, string> = {
  green: 'btn-green-solid',
  white: 'btn-white-solid',
}

const outlineClasses: Record<string, string> = {
  green: 'btn-green-outline',
  white: 'btn-white-outline',
}

const textClasses: Record<string, string> = {
  green: 'btn-green-text',
  white: 'btn-white-text',
}

const iconClasses: Record<string, string> = {
  green: 'btn-green-icon',
  white: 'btn-white-icon',
}

const colourClass =
  style === 'outline'
    ? outlineClasses[colour]
    : style === 'text'
      ? textClasses[colour]
      : style === 'icon'
        ? iconClasses[colour]
        : solidClasses[colour]
const classes = clsx('btn', colourClass, className, sizeClasses[size])
---

{
  tag === 'span' ? (
    <span class={classes} {...rest}>
      <slot />
    </span>
  ) : href ? (
    <a href={href} class={classes} target={target} rel={rel} {...rest}>
      <slot />
    </a>
  ) : (
    <button type={type} class={classes} {...rest}>
      <slot />
    </button>
  )
}
