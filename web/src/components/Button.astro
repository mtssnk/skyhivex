---
import clsx from 'clsx'
interface Props {
  colour?: 'green' | 'white'
  size?: 'lg' | 'md' | 'sm'
  style?: 'solid' | 'outline'
  href?: string
  target?: string
  rel?: string
  type?: 'button' | 'submit' | 'reset'
  class?: string
}

const {
  colour = 'green',
  size = 'md',
  style = 'solid',
  href,
  target,
  rel,
  type = 'button',
  class: className,
  ...rest
} = Astro.props

const sizeClasses: Record<string, string> = {
  lg: 'btn-lg',
  md: 'btn-md',
}

const solidClasses: Record<string, string> = {
  green: 'btn-green-solid',
  white: 'btn-white-solid',
}

const outlineClasses: Record<string, string> = {
  green: 'btn-green-outline',
  white: 'btn-white-outline',
}

const colourClass = style === 'outline' ? outlineClasses[colour] : solidClasses[colour]
const classes = clsx('btn', colourClass, className, sizeClasses[size])
---

{
  href ? (
    <a href={href} class={classes} target={target} rel={rel} {...rest}>
      <slot />
    </a>
  ) : (
    <button type={type} class={classes} {...rest}>
      <slot />
    </button>
  )
}
